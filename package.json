  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "prisma generate && node scripts/migrate-and-seed-if-db.mjs && next build",
    "start": "next start",
    "test": "vitest run",
